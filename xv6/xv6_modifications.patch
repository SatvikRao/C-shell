@@ -81,8 +81,31 @@ usertrap(void)
     kexit(-1);
 
   // give up the CPU if this is a timer interrupt.
-  if(which_dev == 2)
-    yield();
+  if(which_dev == 2){
+    acquire(&tickslock);
+    ticks++;
+    wakeup(&ticks);
+    release(&tickslock);
+    #ifdef CFS
+    struct proc *p = myproc();
+    if(p && p->state == RUNNING){
+      // account 1 tick of runtime into vruntime (weighted)
+      update_vruntime_on_tick(p);
+
+      // consume timeslice
+      if(--p->slice_left <= 0){
+        yield(); // preempt at end of slice
+      }
+    }
+#else
+#ifdef FCFS
+    // FCFS is non-preemptive: do NOT yield here
+#else
+    // RR default: xv6 normally does this
+    if(myproc() && myproc()->state == RUNNING) yield();
+#endif
+#endif
+  }
 
   prepare_return();
 
