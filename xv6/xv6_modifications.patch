+    // time slice = max(3, 48 / nrunnable)
+    int target_latency = 48;
+    int base_slice = target_latency / nr;
+    if(base_slice < 3) base_slice = 3;
+
+    // Pass 1: find the min-vruntime candidate WITHOUT keeping any locks
+    struct proc *best = 0;
+    uint64 best_vr = 0;
+
+    for(struct proc *p = proc; p < &proc[NPROC]; p++){
+      acquire(&p->lock);
+      if(p->state == RUNNABLE){
+        if(best == 0 || p->vruntime < best_vr){
+          best = p;
+          best_vr = p->vruntime;
+        }
+      }
+      release(&p->lock);
+    }
