@@ -20,6 +20,40 @@ static void freeproc(struct proc *p);
 
 extern char trampoline[]; // trampoline.S
 
+extern uint ticks; 
+
+#ifdef CFS
+// Integer fixed-point-ish step: multiply or divide by 5/4 per nice step.
+int calc_weight(int nice) {
+  // clamp to [-20, 19]
+  if (nice < -20) nice = -20;
+  if (nice > 19)  nice = 19;
+
+  long w = 1024; // base at nice=0
+
+  if (nice > 0) {
+    for (int i = 0; i < nice; i++)
+      w = (w * 4) / 5;    // divide by 1.25
+  } else if (nice < 0) {
+    for (int i = 0; i < -nice; i++)
+      w = (w * 5) / 4;    // multiply by 1.25
+  }
+
+  if (w < 15) w = 15;           // floor to spec's lowest weight
+  if (w > 88761) w = 88761;     // cap to spec's highest weight
+  return (int)w;
+}
+
+void update_vruntime_on_tick(struct proc *p){
+  if(!p) return;
+  // scale vruntime by 1024/weight to normalize
+  // Use 64-bit to avoid overflow.
+  uint64 inc = (uint64)1024;
+  inc = (inc * 1) / (p->weight ? p->weight : 1);
+  if(inc < 1) inc = 1; // ensure progress
+  p->vruntime += inc;
+}
+#endif
 // helps ensure that wakeups of wait()ing
 // parents are not lost. helps obey the
 // memory model when using p->parent.
@@ -146,6 +180,15 @@ found:
   p->context.ra = (uint64)forkret;
   p->context.sp = p->kstack + PGSIZE;
 
+    p->ctime = ticks;     // record birth time for FCFS
+
+#ifdef CFS
+  p->nice = 0;
+  p->weight = calc_weight(0);
+  p->vruntime = 0;
+  p->slice_left = 0;
+#endif
+
   return p;
 }
 
